            distance.Visible  = true;
            distance.Position = pos;
            distance.Text     = text;
            if (shadow) then
                  shadow.Visible  = true;
                  shadow.Position = pos + Vector2.new(1, 1);
                  shadow.Text     = text;
                  shadow.Size     = distance.Size;
                  shadow.Font     = distance.Font;
            end;
      end;

      espLibrary.entityESP = entityESP;
end;

