local cloneref          = cloneref or function(...) return ...; end;
local compareinstances  = compareinstances or rawequal;

local runService        = cloneref(game:GetService('RunService'));

local currentCamera     = cloneref(workspace.CurrentCamera);

-- Create ScreenGui for all ESP elements
local espGui = Instance.new('ScreenGui');
espGui.Name = 'ESPGui';
espGui.ResetOnSpawn = false;
espGui.IgnoreGuiInset = true;
espGui.Parent = game:GetService('CoreGui');

local createFrame = function(_name, properties)
      local frame = Instance.new('Frame');
      frame.Name = _name;
      frame.Parent = espGui;
      
      -- Apply default properties
      frame.Visible = false;
      frame.BackgroundColor3 = Color3.new(1, 1, 1);
      frame.BorderSizePixel = 0;
      
      -- Apply custom properties
      for i, value in pairs(properties) do
            frame[i] = value;
      end;
      
      return frame;
end;

local createTextLabel = function(_name, properties)
      local textLabel = Instance.new('TextLabel');
      textLabel.Name = _name;
      textLabel.Parent = espGui;
      
      -- Apply default properties
      textLabel.Visible = false;
      textLabel.BackgroundTransparency = 1;
      textLabel.TextColor3 = Color3.new(1, 1, 1);
      textLabel.TextScaled = true;
      textLabel.TextStrokeTransparency = 0.5;
      textLabel.TextStrokeColor3 = Color3.new(0, 0, 0);
      
      -- Apply custom properties
      for i, value in pairs(properties) do
            textLabel[i] = value;
      end;
      
      return textLabel;
end;

local getBoundingBox = function(model, isPlayer: boolean?)
      if (isPlayer) then
            return model:ComputeR15BodyBoundingBox();
      end;

      return model:GetBoundingBox();
end;

local worldToViewPoint = function(position)
      local pos, onscreen = currentCamera:WorldToViewportPoint(position);
      return Vector2.new(pos.X, pos.Y), onscreen, pos.Z;
end;

local executor 	= identifyexecutor and identifyexecutor() or 'unknown';

local GLOBAL_FONT = Enum.Font.GothamBold;
local GLOBAL_SIZE	= 14;

local BASE_ZINDEX = 1;

local espLibrary = {};


-- playerESP
do
      local playerESP = {
            playerCache = {};
            drawingCache = {};
            allDrawingCache = {};

            childAddedConnections = {};
            childRemovedConnections = {};

            drawingAddedConnections = {};
      };
      playerESP.__index = playerESP;

      -- preload
      playerESP.onChildAdded = function(_function)
            table.insert(playerESP.childAddedConnections, _function);
      end;
      playerESP.onChildRemoved = function(_function)
            table.insert(playerESP.childRemovedConnections, _function);
      end;
      playerESP.onDrawingAdded = function(_func)
            table.insert(playerESP.drawingAddedConnections, _func);
      end;


      playerESP.new = function(player: Player)
            local self = setmetatable({
                  player      = player;
                  connections = {};
                  hidden      = false;
                  allDrawings = nil;
                  drawings    = nil;
                  current     = nil;
            }, playerESP);

            self:createDrawingCache();

            for i = 1, #playerESP.drawingAddedConnections do
                  playerESP.drawingAddedConnections[i](self);
            end;

            table.insert(self.connections, player.CharacterAdded:Connect(function(...)
                  return self:characterAdded(...);
            end));
            table.insert(self.connections, player.CharacterRemoving:Connect(function(...)
                  return self:characterRemoved(...);
            end));

            if (player.Character) then
                  self:characterAdded(player.Character, true);
            end;

            playerESP.playerCache[player] = self;

            return self;
      end;
      playerESP.remove = function(player: Player)
            local cache = playerESP.playerCache[player];
            if (type(cache) ~= 'table' or type(cache.drawings) ~= 'table' or type(cache.connections) ~= 'table') then
				return;
			end;
			
			
			playerESP.playerCache[player] = nil;

			
            for i = 1, #cache.connections do
                  cache.connections[i]:Disconnect();
            end;

            for i = 1, #cache.allDrawings do
                  cache.allDrawings[i]:Destroy();
            end;
      end;

      function playerESP:createDrawingCache()
            local allDrawings = {};
            local drawings = {
                  boxFrame = createFrame('BoxFrame', {
                        BackgroundTransparency = 0.5;
                        BackgroundColor3 = Color3.new(1, 1, 1);
                        BorderSizePixel = 1;
                        BorderColor3 = Color3.new(0, 0, 0);
                        ZIndex = BASE_ZINDEX + 1;
                  }),
                  
                  cornerRadius = Instance.new('UICorner'),

                  name = createTextLabel('NameLabel', {
                        Font = GLOBAL_FONT;
                        TextSize = GLOBAL_SIZE;
                        ZIndex = BASE_ZINDEX + 2;
                  }),
                  distance = createTextLabel('DistanceLabel', {
                        Font = GLOBAL_FONT;
                        TextSize = GLOBAL_SIZE;
                        ZIndex = BASE_ZINDEX + 2;
                  }),
                  weapon = createTextLabel('WeaponLabel', {
                        Font = GLOBAL_FONT;
                        TextSize = GLOBAL_SIZE;
                        ZIndex = BASE_ZINDEX + 2;
                  }),

                  healthBarContainer = createFrame('HealthBarContainer', {
                        BackgroundColor3 = Color3.new(0.2, 0.2, 0.2);
                        BackgroundTransparency = 0.3;
                        BorderSizePixel = 1;
                        BorderColor3 = Color3.new(0, 0, 0);
                        ZIndex = BASE_ZINDEX + 1;
                  }),

                  healthBarContainerCorner = Instance.new('UICorner'),

                  healthBar = createFrame('HealthBar', {
                        BackgroundColor3 = Color3.new(0, 1, 0);
                        BorderSizePixel = 0;
                        ZIndex = BASE_ZINDEX + 2;
                  }),

                  healthBarCorner = Instance.new('UICorner'),

                  -- Gradient elements for healthbar
                  healthGradient = Instance.new('UIGradient'),
            };

            -- Setup corner radius
            drawings.cornerRadius.CornerRadius = UDim.new(0, 4);
            drawings.cornerRadius.Parent = drawings.boxFrame;

            -- Setup health bar corner radius
            drawings.healthBarContainerCorner.CornerRadius = UDim.new(0, 3);
            drawings.healthBarContainerCorner.Parent = drawings.healthBarContainer;

            drawings.healthBarCorner.CornerRadius = UDim.new(0, 3);
            drawings.healthBarCorner.Parent = drawings.healthBar;

            -- Setup gradient for health bar
            drawings.healthGradient.Parent = drawings.healthBar;
            drawings.healthGradient.Rotation = 90;

            drawings.name.Text = self.player.DisplayName;

            allDrawings = {
                  drawings.boxFrame,
                  drawings.name,
                  drawings.distance,
                  drawings.weapon,
                  drawings.healthBarContainer,
                  drawings.healthBar,
            };

            self.drawings = drawings;
            self.allDrawings = allDrawings;
      end;

      function playerESP:hideDrawings()
            if (self.hidden) then
                  return;
            end;
            self.hidden = true;
            for i = 1, #self.allDrawings do
                  self.allDrawings[i].Visible = false;
            end;
      end;

      function playerESP:showDrawings()
            if (not self.hidden) then
                  return;
            end;
            self.hidden = false;
            for i = 1, #self.allDrawings do
                  self.allDrawings[i].Visible = true;
            end;
      end;

      function playerESP:characterAdded(character: Model, noCharacterTest: boolean?)
            local humanoidRootPart = character:FindFirstChild('HumanoidRootPart');
            if (not humanoidRootPart) then
                  return;
            end;

            self.current = character;
      end;

      function playerESP:characterRemoved()
            self.current = nil;
      end;

      function playerESP:humanoidHealthChanged()
            local humanoid = self.current:FindFirstChild('Humanoid');
            if (not humanoid) then
                  return;
            end;

            local health = humanoid.Health;
            local maxHealth = humanoid.MaxHealth;
            local healthPercentage = health / maxHealth;

            self.health = health;
            self.maxHealth = maxHealth;
            self.healthPercentage = healthPercentage;

            -- Update gradient colors based on health
            local healthColor = Color3.new(1, 0, 0):Lerp(Color3.new(0, 1, 0), healthPercentage);
            self.drawings.healthGradient.Color = ColorSequence.new({
                  ColorSequenceKeypoint.new(0, healthColor);
                  ColorSequenceKeypoint.new(1, healthColor:Lerp(Color3.new(1, 1, 1), 0.3));
            });
      end;

      function playerESP:loop(settings, distance)
            if (not self.current or not self.player.Character) then
                  return self:hideDrawings();
            end;

            local humanoid = self.current:FindFirstChild('Humanoid');
            local humanoidRootPart = self.current:FindFirstChild('HumanoidRootPart');

            if (not humanoidRootPart or not humanoid or humanoid.Health <= 0) then
                  return self:hideDrawings();
            end;

            local goal, size = getBoundingBox(self.current, true);
            local vector2, onscreen = worldToViewPoint(goal.Position);

            if (not onscreen) then
                  return self:hideDrawings();
            end;

            self.hidden = false;

            local cframe = CFrame.new(goal.Position, currentCamera.CFrame.Position);

            local x, y = -size.X / 2, size.Y / 2;
            local topright = worldToViewPoint((cframe * CFrame.new(x, y, 0)).Position);
            local bottomright = worldToViewPoint((cframe * CFrame.new(x, -y, 0)).Position);

            local offset = Vector2.new(
                  math.max(topright.X - vector2.X, bottomright.X - vector2.X),
                  math.max((vector2.Y - topright.Y), (bottomright.Y - vector2.Y))
            );

            if (settings.box) then
                  self:renderBox(vector2, offset);
            else
                  self.drawings.boxFrame.Visible = false;
            end;

            if (settings.name) then
                  self:renderName(vector2, offset);
            else
                  self.drawings.name.Visible = false;
            end;

            if (settings.distance) then
                  self:renderDistance(vector2, offset, distance);
            else
                  self.drawings.distance.Visible = false;
            end;

            if (settings.weapon) then
                  self:renderWeapon(vector2, offset);
            else
                  self.drawings.weapon.Visible = false;
            end;

            if (settings.healthbar) then
                  self:humanoidHealthChanged();
                  self:renderHealthbar(vector2, offset);
            else
                  self.drawings.healthBarContainer.Visible = false;
                  self.drawings.healthBar.Visible = false;
            end;
      end;

      function playerESP:renderBox(vector2, offset)
            local boxFrame = self.drawings.boxFrame;

            local position = vector2 - offset;
            local size = offset * 2;

            boxFrame.Visible = true;
            boxFrame.Position = UDim2.new(0, position.X, 0, position.Y);
            boxFrame.Size = UDim2.new(0, size.X, 0, size.Y);
      end;

      function playerESP:renderName(vector2, offset)
            local nameLabel = self.drawings.name;

            nameLabel.Visible = true;
            nameLabel.Size = UDim2.new(0, offset.X * 2, 0, 20);
            nameLabel.Position = UDim2.new(0, vector2.X - offset.X, 0, vector2.Y - offset.Y - 25);
      end;

      function playerESP:renderDistance(vector2, offset, _distance)
            local distanceLabel = self.drawings.distance;

            local magnitude = math.round(_distance or (currentCamera.CFrame.Position - self.current:FindFirstChild('HumanoidRootPart').Position).Magnitude);

            distanceLabel.Visible = true;
            distanceLabel.Size = UDim2.new(0, offset.X * 2, 0, 20);
            distanceLabel.Position = UDim2.new(0, vector2.X - offset.X, 0, vector2.Y + offset.Y + 5);
            distanceLabel.Text = `[{magnitude}]`;
      end;

      function playerESP:renderWeapon(vector2, offset)
            local weaponLabel = self.drawings.weapon;
            
            local character = self.current;
            local weapon = character:FindFirstChildOfClass('Tool');

            weaponLabel.Visible = weapon ~= nil;
            if (weapon) then
                  weaponLabel.Size = UDim2.new(0, offset.X * 2, 0, 20);
                  weaponLabel.Position = UDim2.new(0, vector2.X - offset.X, 0, vector2.Y + offset.Y + 30);
                  weaponLabel.Text = weapon.Name;
            end;
      end;

      function playerESP:renderHealthbar(vector2, offset)
            local healthBarContainer = self.drawings.healthBarContainer;
            local healthBar = self.drawings.healthBar;

            healthBarContainer.Visible = true;
            healthBar.Visible = true;

            local containerWidth = 4;
            local containerHeight = offset.Y * 2;
            local basePosition = vector2 - offset - Vector2.new(10, 0);

            healthBarContainer.Position = UDim2.new(0, basePosition.X, 0, basePosition.Y);
            healthBarContainer.Size = UDim2.new(0, containerWidth, 0, containerHeight);

            local healthLength = (containerHeight - 4) * self.healthPercentage;
            local healthPosition = basePosition + Vector2.new(2, 2 + (containerHeight - 4 - healthLength));

            healthBar.Position = UDim2.new(0, healthPosition.X, 0, healthPosition.Y);
            healthBar.Size = UDim2.new(0, containerWidth - 4, 0, healthLength);
      end;

      espLibrary.playerESP = playerESP;
end;


-- npcESP
do
      local npcESP = {
            npcCache = {};
            drawingCache = {};
            allDrawingCache = {};

            childAddedConnections = {};
            childRemovedConnections = {};

            drawingAddedConnections = {};
      };
      npcESP.__index = npcESP;

      npcESP.onChildAdded = function(_function)
            table.insert(npcESP.childAddedConnections, _function);
      end;
      npcESP.onChildRemoved = function(_function)
            table.insert(npcESP.childRemovedConnections, _function);
      end;
      npcESP.onDrawingAdded = function(_func)
            table.insert(npcESP.drawingAddedConnections, _func);
      end;

      npcESP.new = function(entity: Model, name: string, colour: Color3)
            local self = setmetatable({
                  entity       = entity;
                  name         = name;
                  colour       = colour;
                  humanoid     = entity:FindFirstChild('Humanoid');
                  connections  = {};
                  hidden       = false;
                  allDrawings  = nil;
                  drawings     = nil;

                  health       = 0;
                  maxHealth    = 0;
                  healthPercentage = 0;

                  ignoreR15    = false;
            }, npcESP);

            self:createDrawingCache();

            for i = 1, #npcESP.drawingAddedConnections do
                  npcESP.drawingAddedConnections[i](self);
            end;

            if (self.humanoid) then
                  self:setupHumanoid(self.humanoid);
            end;

            npcESP.npcCache[entity] = self;

            return self;
      end;
      npcESP.remove = function(entity: Model)
            local cache = npcESP.npcCache[entity];
            if (type(cache) ~= 'table' or type(cache.drawings) ~= 'table' or type(cache.connections) ~= 'table') then
				return;
			end;
			
			npcESP.npcCache[entity] = nil;

            for i = 1, #cache.connections do
                  cache.connections[i]:Disconnect();
            end;

            for i = 1, #cache.allDrawings do
                  cache.allDrawings[i]:Destroy();
            end;
      end;

      function npcESP:createDrawingCache()
            local allDrawings = {};

            local drawings = {
                  boxFrame = createFrame('NPCBoxFrame', {
                        BackgroundTransparency = 0.5;
                        BackgroundColor3 = self.colour;
                        BorderSizePixel = 1;
                        BorderColor3 = Color3.new(0, 0, 0);
                        ZIndex = BASE_ZINDEX + 1;
                  }),

                  cornerRadius = Instance.new('UICorner'),

                  name = createTextLabel('NPCNameLabel', {
                        Font = GLOBAL_FONT;
                        TextSize = GLOBAL_SIZE;
                        TextColor3 = self.colour;
                        ZIndex = BASE_ZINDEX + 2;
                  }),
                  distance = createTextLabel('NPCDistanceLabel', {
                        Font = GLOBAL_FONT;
                        TextSize = GLOBAL_SIZE;
                        TextColor3 = self.colour;
                        ZIndex = BASE_ZINDEX + 2;
                  }),

                  healthBarContainer = createFrame('NPCHealthBarContainer', {
                        BackgroundColor3 = Color3.new(0.2, 0.2, 0.2);
                        BackgroundTransparency = 0.3;
                        BorderSizePixel = 1;
                        BorderColor3 = Color3.new(0, 0, 0);
                        ZIndex = BASE_ZINDEX + 1;
                  }),

                  healthBarContainerCorner = Instance.new('UICorner'),

                  healthBar = createFrame('NPCHealthBar', {
                        BackgroundColor3 = Color3.new(0, 1, 0);
                        BorderSizePixel = 0;
                        ZIndex = BASE_ZINDEX + 2;
                  }),

                  healthBarCorner = Instance.new('UICorner'),

                  healthGradient = Instance.new('UIGradient'),
            };

            -- Setup corner radius for box
            drawings.cornerRadius.CornerRadius = UDim.new(0, 4);
            drawings.cornerRadius.Parent = drawings.boxFrame;

            -- Setup corner radius for health bars
            drawings.healthBarContainerCorner.CornerRadius = UDim.new(0, 3);
            drawings.healthBarContainerCorner.Parent = drawings.healthBarContainer;

            drawings.healthBarCorner.CornerRadius = UDim.new(0, 3);
            drawings.healthBarCorner.Parent = drawings.healthBar;

            -- Setup gradient
            drawings.healthGradient.Parent = drawings.healthBar;
            drawings.healthGradient.Rotation = 90;

            drawings.name.Text = self.name;

            allDrawings = {
                  drawings.boxFrame,
                  drawings.name,
                  drawings.distance,
                  drawings.healthBarContainer,
                  drawings.healthBar,
            };

            self.drawings = drawings;
            self.allDrawings = allDrawings;
      end;

      function npcESP:hideDrawings()
            if (self.hidden) then
                  return;
            end;

            self.hidden = true;
            for i = 1, #self.allDrawings do
                  self.allDrawings[i].Visible = false;
            end;
      end;

      function npcESP:loop(settings, distance)

            local useR15 = self.humanoid ~= nil and not self.ignoreR15;
            local goal, size = getBoundingBox(useR15 and self.humanoid or self.entity, useR15);

            local vector2, onscreen = worldToViewPoint(goal.Position);
            if (not onscreen) then
                  return self:hideDrawings();
            end;
            self.hidden = false;

            local cframe = CFrame.new(goal.Position, currentCamera.CFrame.Position);

            local x, y = -size.X / 2, size.Y / 2;
            local topright    = worldToViewPoint((cframe * CFrame.new(x, y, 0)).Position)
            local bottomright = worldToViewPoint((cframe * CFrame.new(x, -y, 0)).Position)

            local offset = Vector2.new(
                  math.max(topright.X - vector2.X, bottomright.X - vector2.X),
                  math.max((vector2.Y - topright.Y), (bottomright.Y - vector2.Y))
            );

            if (settings.box) then
                  self:renderBox(vector2, offset);
            else
                  self.drawings.boxFrame.Visible = false;
            end;

            if (settings.name) then
                  self:renderName(vector2, offset);
            else
                  self.drawings.name.Visible = false;
            end;

            if (settings.distance) then
                  self:renderDistance(vector2, offset, distance);
            else
                  self.drawings.distance.Visible = false;
            end;

            if (settings.healthbar) then
                  self:renderHealthbar(vector2, offset);
            else
                  self.drawings.healthBarContainer.Visible = false;
                  self.drawings.healthBar.Visible = false;
            end;
      end;
      
      function npcESP:humanoidHealthChanged()
            local humanoid          = self.humanoid;

            local health            = humanoid.Health;
            local maxHealth         = humanoid.MaxHealth;

            local healthPercentage  = health / maxHealth;
            
            self.health             = health;
            self.maxHealth          = maxHealth;
            self.healthPercentage   = healthPercentage;

            -- Update gradient colors based on health
            local healthColor = Color3.new(1, 0, 0):Lerp(Color3.new(0, 1, 0), healthPercentage);
            self.drawings.healthGradient.Color = ColorSequence.new({
                  ColorSequenceKeypoint.new(0, healthColor);
                  ColorSequenceKeypoint.new(1, healthColor:Lerp(Color3.new(1, 1, 1), 0.3));
            });
      end;

      function npcESP:setupHumanoid(humanoid: Humanoid)

            self:humanoidHealthChanged();

            table.insert(self.connections, humanoid:GetPropertyChangedSignal('Health'):Connect(function()
                  self:humanoidHealthChanged();
            end));
      end;


      -- render functions
      function npcESP:renderBox(vector2, offset)
            local drawings = self.drawings;

            local fill        = drawings.boxFrame;

            local position    = vector2 - offset;
            local size        = offset * 2;
            
            fill.Visible      = true;
            fill.Position     = UDim2.new(0, position.X, 0, position.Y);
            fill.Size         = UDim2.new(0, size.X, 0, size.Y);
      end;

      function npcESP:renderName(vector2, offset)
            local name = self.drawings.name;

            name.Visible      = true;
            name.Size         = UDim2.new(0, offset.X * 2, 0, 20);
            name.Position     = UDim2.new(0, vector2.X - offset.X, 0, vector2.Y - offset.Y - 25);
      end;

      function npcESP:renderDistance(vector2, offset, _distance)
            local distance = self.drawings.distance;

            local magnitude   = math.round( _distance or (currentCamera.CFrame.Position - self.entity:GetPivot().Position).Magnitude );
            
            distance.Visible  = true;
            distance.Size     = UDim2.new(0, offset.X * 2, 0, 20);
            distance.Position = UDim2.new(0, vector2.X - offset.X, 0, vector2.Y + offset.Y + 5);
            distance.Text     = `[{magnitude}]`;
      end;

      function npcESP:renderHealthbar(vector2, offset)
            local healthBar         = self.drawings.healthBar;
            local healthBackground  = self.drawings.healthBarContainer;

            healthBar.Visible = true;
            healthBackground.Visible = true;

            local containerWidth = 4;
            local containerHeight = offset.Y * 2;
            local basePosition = vector2 - offset - Vector2.new(10, 0);

            healthBackground.Position = UDim2.new(0, basePosition.X, 0, basePosition.Y);
            healthBackground.Size = UDim2.new(0, containerWidth, 0, containerHeight);

            local healthLength = (containerHeight - 4) * self.healthPercentage;
            local healthPosition = basePosition + Vector2.new(2, 2 + (containerHeight - 4 - healthLength));

            healthBar.Position = UDim2.new(0, healthPosition.X, 0, healthPosition.Y);
            healthBar.Size = UDim2.new(0, containerWidth - 4, 0, healthLength);
      end;


      espLibrary.npcESP = npcESP;
end;


return espLibrary, 3;
